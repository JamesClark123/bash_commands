# :command.initialize
initialize() {
  declare -g version="0.1.0"
  set -e

}

# :command.run
run() {
  # :command.globals
  declare -g long_usage=''
  declare -g -A args=()
  declare -g -a other_args=()
  declare -g -A deps=()
  declare -g -a env_var_names=()
  declare -g -a input=()

  normalize_input "$@"
  parse_requirements "${input[@]}"

  case "$action" in
    "log") git_cli_log_command ;;
    "status") git_cli_status_command ;;
    "diff") git_cli_diff_command ;;
    "checkout") git_cli_checkout_command ;;
    "add") git_cli_add_command ;;
    "commit") git_cli_commit_command ;;
    "push") git_cli_push_command ;;
    "pull") git_cli_pull_command ;;
    "fetch") git_cli_fetch_command ;;
    "rebase") git_cli_rebase_command ;;
    "reset") git_cli_reset_command ;;
    "restore") git_cli_restore_command ;;
    "cherry-pick") git_cli_cherry_pick_command ;;
    "clean") git_cli_clean_command ;;
    "update") git_cli_update_command ;;
    "completions") git_cli_completions_command ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
