# :command.parse_requirements
parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --version | -v)
        version_command
        exit
        ;;

      --help | -h)
        long_usage=yes
        git_cli_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action=${1:-}

  case $action in
    -*) ;;

    log | l)
      action="log"
      shift
      git_cli_log_parse_requirements "$@"
      shift $#
      ;;

    status | s)
      action="status"
      shift
      git_cli_status_parse_requirements "$@"
      shift $#
      ;;

    diff | d)
      action="diff"
      shift
      git_cli_diff_parse_requirements "$@"
      shift $#
      ;;

    checkout | co)
      action="checkout"
      shift
      git_cli_checkout_parse_requirements "$@"
      shift $#
      ;;

    add | a)
      action="add"
      shift
      git_cli_add_parse_requirements "$@"
      shift $#
      ;;

    commit | c)
      action="commit"
      shift
      git_cli_commit_parse_requirements "$@"
      shift $#
      ;;

    push | ph)
      action="push"
      shift
      git_cli_push_parse_requirements "$@"
      shift $#
      ;;

    pull | pl)
      action="pull"
      shift
      git_cli_pull_parse_requirements "$@"
      shift $#
      ;;

    fetch | f)
      action="fetch"
      shift
      git_cli_fetch_parse_requirements "$@"
      shift $#
      ;;

    rebase | r)
      action="rebase"
      shift
      git_cli_rebase_parse_requirements "$@"
      shift $#
      ;;

    reset | rt)
      action="reset"
      shift
      git_cli_reset_parse_requirements "$@"
      shift $#
      ;;

    restore | re)
      action="restore"
      shift
      git_cli_restore_parse_requirements "$@"
      shift $#
      ;;

    cherry-pick | cp)
      action="cherry-pick"
      shift
      git_cli_cherry_pick_parse_requirements "$@"
      shift $#
      ;;

    clean)
      action="clean"
      shift
      git_cli_clean_parse_requirements "$@"
      shift $#
      ;;

    update | u)
      action="update"
      shift
      git_cli_update_parse_requirements "$@"
      shift $#
      ;;

    completions)
      action="completions"
      shift
      git_cli_completions_parse_requirements "$@"
      shift $#
      ;;

    # :command.command_fallback
    "")
      git_cli_usage >&2
      exit 1
      ;;

    *)
      printf "invalid command: %s\n" "$action" >&2
      exit 1
      ;;

  esac

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

}

